{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Email Service",
            "type": "shell",
            "command": "python",
            "args": ["start_continuous_email_service.py"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Start the continuous email service in background"
        },
        {
            "label": "Check Email Service Status",
            "type": "shell",
            "command": "python",
            "args": ["email_service_status.py"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Check the current status of the email service"
        },
        {
            "label": "Auto-Start Email Service",
            "type": "shell",
            "command": "python",
            "args": ["auto_start_email_service.py"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Automatically start email service if not running"
        }
    ]
